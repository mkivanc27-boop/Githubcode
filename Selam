    clear()
    art = r"""
   _____ ____  ____
  / ___// __ \/ ___/
  \__ \/ / / / /
 ___/ / /_/ / /___
/____/\____/\____/   Security Operations Center
"""
    print(f"{GREEN}{art}{RESET}")
    time.sleep(0.3)

    scenario = [
        ("ALARM: Anormal trafik tespit edildi...", RED,    0.018),
        ("ALARM: Saniyede 8.400 istek — normal: 200",    RED,    0.015),
        ("ALARM: 47 farklı ülkeden koordineli saldırı!", RED,    0.015),
        ("ALARM: SUNUCU KAPASITESI AŞILDI — SERVİS DIŞI",RED,   0.018),
        ("",                                              DIM,    0),
        ("SOC ekibi devreye girdi. Sen komuta geçiyorsun.", CYAN, 0.015),
        ("Görevi: Saldırıyı durdur, sistemi koru, servisi geri getir.", DIM, 0.013),
