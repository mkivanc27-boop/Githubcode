def main():
    boot()
    state = SOCState()
    state.load = 1350
    state.history = [random.randint(900,1400) for _ in range(15)]
    state.add_log("CRIT", "DDoS saldırısı başladı — 8400 req/s")
    state.add_log("CRIT", f"SQL Injection: {random.choice(BOTNET_IPS)} → /login payload: ' OR '1'='1")
    state.add_log("WARN", f"Anormal trafik: {random.choice(BOTNET_IPS)} [RU] 450 req/s")
    state.add_alert("Sunucu kapasitesi aşıldı!")
    state.add_alert("SQL Injection girişimi!")

    last_tick = None
    dashboard(state, last_tick)

    while True:
        try:
            raw = input(f"{GREEN}soc@defense{RESET}:{YELLOW}~${RESET} ").strip()
        except (EOFError, KeyboardInterrupt):
            print(f"\n{DIM}Oturum kapatılıyor...{RESET}")
            break

        if not raw: continue
        parts = raw.split()
        cmd = parts[0].lower()
        args = parts[1:]

        # ── Durum güncellemesi gerektirmeyen komutlar
        if cmd == "exit":
            slow("SOC oturumu kapatılıyor...", DIM)
            cmd_report(state)
            break
        elif cmd == "help":     cmd_help(); continue
        elif cmd == "logs":     cmd_logs(state, args); continue
        elif cmd == "tickets":  cmd_tickets(state); continue
        elif cmd == "score":    cmd_score(state); continue
        elif cmd == "explain":  cmd_explain(args[0].lower() if args else ""); continue

        # ── Tick tetikleyen komutlar
