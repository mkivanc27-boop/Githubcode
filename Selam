# ── Renkler ────────────────────────────────────────────────────────────
RED    = "\033[91m"
GREEN  = "\033[92m"
YELLOW = "\033[93m"
CYAN   = "\033[96m"
WHITE  = "\033[97m"
DIM    = "\033[90m"
BOLD   = "\033[1m"
BLINK  = "\033[5m"
RESET  = "\033[0m"

def clear(): os.system("cls" if os.name == "nt" else "clear")
def now(): return datetime.now().strftime("%H:%M:%S")

def slow_print(text, color=DIM, delay=0.013):
    print(color, end="", flush=True)
    for ch in text:
        print(ch, end="", flush=True)
        time.sleep(delay)
    print(RESET)

# ── Simülasyon State ────────────────────────────────────────────────────
class ServerState:
    def __init__(self):
        self.max_capacity   = 1000   # saniyede max istek
        self.current_load   = 0
        self.is_down        = False
        self.firewall_rules = []     # engellenen IP'ler
        self.rate_limits    = {}     # IP -> limit
        self.cdn_active     = False
        self.load_balancer  = False
        self.captcha_active = False
        self.blackhole      = False
        self.scrubbing      = False
        self.blocked_count  = 0
        self.passed_count   = 0
        self.attack_log     = deque(maxlen=20)
        self.defense_log    = deque(maxlen=20)
        self.traffic_history = []

# ── Sahte IP üreteci ────────────────────────────────────────────────────
BOTNET_RANGES = [
    "185.220.{}.{}", "45.133.{}.{}", "194.165.{}.{}",
    "91.108.{}.{}",  "103.75.{}.{}",  "198.54.{}.{}",
]
NORMAL_RANGES = [
    "78.160.{}.{}", "88.247.{}.{}", "5.26.{}.{}",
]

def fake_ip(botnet=True):
    tpl = random.choice(BOTNET_RANGES if botnet else NORMAL_RANGES)
    return tpl.format(random.randint(1,254), random.randint(1,254))

def fake_request():
    paths = ["/", "/login", "/api/data", "/search", "/checkout", "/static/js/app.js"]
    return random.choice(paths)

# ── Saldırı simülatörü ──────────────────────────────────────────────────
def simulate_attack(state, intensity=1.0):
    """Her 'tick'te saldırı trafiği üret"""
    bot_count   = int(random.randint(200, 400) * intensity)
    legit_count = random.randint(30, 80)

    blocked = 0
    passed  = 0

    for _ in range(bot_count):
        ip  = fake_ip(botnet=True)
        req = fake_request()

        # Savunma mekanizmaları
        if ip in state.firewall_rules:
            blocked += 1
            continue
        if state.blackhole:
            blocked += int(bot_count * 0.95)
            passed  += int(bot_count * 0.05)
            break
        if state.scrubbing:
            blocked += int(bot_count * 0.85)
            passed  += int(bot_count * 0.15)
            break
        if state.cdn_active and random.random() < 0.6:
            blocked += 1
            continue
        if state.captcha_active and random.random() < 0.80:
            blocked += 1
            continue
        passed += 1

    for _ in range(legit_count):
        if state.load_balancer or state.cdn_active:
            passed += 1
        else:
            passed += 1

    state.blocked_count += blocked
    state.passed_count  += passed

    load = min(passed, state.max_capacity + 500)
    state.current_load = load

    if load > state.max_capacity and not state.is_down:
        state.is_down = True

    state.traffic_history.append(load)
    if len(state.traffic_history) > 30:
        state.traffic_history.pop(0)

    return bot_count, legit_count, blocked, passed

# ── Görsel yardımcılar ──────────────────────────────────────────────────
def load_bar(load, capacity):
    pct = min(load / capacity, 1.5)
    filled = int(pct * 30)
    bar = "█" * min(filled, 30) + "░" * max(0, 30 - filled)
    if pct > 1.0:
        color = RED
    elif pct > 0.75:
        color = YELLOW
    else:
        color = GREEN
    return f"{color}[{bar}]{RESET} {load}/{capacity} req/s"

def mini_graph(history):
    if not history: return ""
    mx = max(history) if max(history) > 0 else 1
    bars = " ▁▂▃▄▅▆▇█"
    result = ""
    for v in history[-20:]:
        idx = min(int((v / mx) * 8), 8)
        color = RED if v > 1000 else YELLOW if v > 700 else GREEN
        result += f"{color}{bars[idx]}{RESET}"
    return result

def status_icon(active):
    return f"{GREEN}[AKTİF]{RESET}" if active else f"{DIM}[PASİF]{RESET}"

def print_dashboard(state, attack_info=None):
    clear()
    print(f"{GREEN}{'═'*65}{RESET}")
    print(f"{GREEN}  🛡  ŞİRKET GÜVENLİK OPERASYON MERKEZİ (SOC)         {now()}{RESET}")
    print(f"{GREEN}{'═'*65}{RESET}")

    # Sunucu durumu
    server_status = f"{RED}{BLINK}⚠ ÇÖKTÜ{RESET}" if state.is_down else f"{GREEN}✓ ÇALIŞIYOR{RESET}"
    print(f"\n  Sunucu Durumu   : {server_status}")
    print(f"  Yük             : {load_bar(state.current_load, state.max_capacity)}")
    print(f"  Trafik Grafiği  : {mini_graph(state.traffic_history)}")
    print(f"  Engellenen      : {RED}{state.blocked_count}{RESET}  |  Geçen: {GREEN}{state.passed_count}{RESET}\n")

    # Savunma katmanları
    print(f"  {CYAN}── SAVUNMA KATMANLARI ──────────────────────────────{RESET}")
    print(f"  [1] Firewall IP Block   {status_icon(len(state.firewall_rules)>0)}  ({len(state.firewall_rules)} IP engelli)")
    print(f"  [2] Rate Limiting       {status_icon(bool(state.rate_limits))}")
    print(f"  [3] CDN / Cloudflare    {status_icon(state.cdn_active)}")
    print(f"  [4] Load Balancer       {status_icon(state.load_balancer)}")
    print(f"  [5] CAPTCHA             {status_icon(state.captcha_active)}")
    print(f"  [6] BGP Blackhole       {status_icon(state.blackhole)}")
    print(f"  [7] Traffic Scrubbing   {status_icon(state.scrubbing)}")

    # Son saldırı logu
    if attack_info:
        bot, legit, blocked, passed = attack_info
        print(f"\n  {CYAN}── SON SALDIRI TİCKI ───────────────────────────────{RESET}")
        print(f"  Bot isteği: {RED}{bot}{RESET}  |  Meşru: {GREEN}{legit}{RESET}  |  Engel: {YELLOW}{blocked}{RESET}  |  Geçti: {RED}{passed}{RESET}")

    print(f"\n  {CYAN}── KOMUTLAR ─────────────────────────────────────────{RESET}")
    print(f"  {DIM}firewall <IP>  ratelimit  cdn  loadbalancer  captcha  blackhole  scrubbing  status  next  help  exit{RESET}")

    if state.is_down:
        print(f"\n  {RED}{'█'*55}")
        print(f"  █  KRİTİK: SUNUCU ÇÖKTÜ! SERVİS DIŞI!              █")
        print(f"  █  Savunma katmanlarını aktifleştir!                 █")
        print(f"  {'█'*55}{RESET}")
    print()

