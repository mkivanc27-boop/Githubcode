def main():
    boot()
    conn = setup_db()
    state = {"secure": False, "user": None}

    while True:
        mode_label = f"{GREEN}[GÜVENLİ]{RESET}" if state["secure"] else f"{RED}[SAVUNMASIZ]{RESET}"
        try:
            raw = input(f"{GREEN}elliot@fsociety{RESET}{mode_label}{GREEN}:~${RESET} ")
        except (EOFError, KeyboardInterrupt):
            print(f"\n{DIM}Çıkılıyor...{RESET}")
            break

        parts = raw.strip().split()
        if not parts:
            continue
        cmd = parts[0].lower()
        args = parts[1:]

        if cmd == "exit":
            slow_print("bağlantı kesiliyor...", DIM)
            time.sleep(0.5)
            break
        elif cmd == "clear":
            clear()
        elif cmd == "help":
            cmd_help()
        elif cmd == "users":
            cmd_users()
        elif cmd == "explain":
            cmd_explain()
        elif cmd == "whoami":
            cmd_whoami(state)
        elif cmd == "login":
            cmd_login(conn, args, state)
        elif cmd == "sqlmap":
            cmd_sqlmap(conn, args, state)
        elif cmd == "fix":
            state["secure"] = True
            slow_print("string concatenation → parameterized query ile değiştiriliyor...", DIM)
            time.sleep(0.5)
            slow_print("[✓] yama uygulandı. sistem artık GÜVENLİ.", GREEN)
            print(f"  {DIM}doğrulamak için: sqlmap admin{RESET}\n")
        elif cmd == "unfix":
            state["secure"] = False
            state["user"] = None
            slow_print("[!] savunmasız koda geri dönüldü.", YELLOW)
            print()
        else:
            print(f"  {DIM}komut bulunamadı: {cmd}  ('help' ile komutları gör){RESET}\n")

if __name__ == "__main__":
    main()
