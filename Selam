# ── Sahte veritabanı (sadece bellekte, gerçek bir sisteme bağlanmıyor) ──
def setup_db():
    conn = sqlite3.connect(":memory:")
    conn.execute("""
        CREATE TABLE users (
            id INTEGER, username TEXT, password TEXT,
            role TEXT, clearance TEXT
        )
    """)
    users = [
        (1, "admin",  "Tr0j4n.H0rs3!", "root", "TOP SECRET"),
        (2, "elliot", "mr_r0bot_2015",  "user", "LEVEL 2"),
        (3, "tyrell", "wellick_ceo",    "exec", "LEVEL 4"),
        (4, "angela", "ang3la_m0ss",    "user", "LEVEL 1"),
    ]
    conn.executemany("INSERT INTO users VALUES (?,?,?,?,?)", users)
    conn.commit()
    return conn

# ── Yardımcı fonksiyonlar ───────────────────────────────────────────────
def clear():
    os.system("cls" if os.name == "nt" else "clear")

def slow_print(text, color=DIM, delay=0.012):
    print(color, end="", flush=True)
    for ch in text:
        print(ch, end="", flush=True)
        time.sleep(delay)
    print(RESET)

def glitch():
    chars = "!@#$%^&*<>?/\\|~`"
    line = "".join(random.choice(chars) for _ in range(random.randint(20, 50)))
    print(f"\033[91m{line}\033[0m")
    time.sleep(0.06)
    print("\033[1A\033[2K", end="")  # bir satır sil

# ── Giriş fonksiyonları ────────────────────────────────────────────────
def vulnerable_login(conn, username, password):
    # KÖTÜ: string birleştirme — injection açığı var!
    query = f"SELECT * FROM users WHERE username='{username}' AND password='{password}'"
    print(f"\n  {DIM}[SQL] {CYAN}{query}{RESET}\n")
    time.sleep(0.3)
    try:
        result = conn.execute(query).fetchone()
        return result
    except Exception as e:
        print(f"  {RED}[SQL HATA] {e}{RESET}")
        return None

def secure_login(conn, username, password):
    # İYİ: parameterized query — injection imkansız!
    query = "SELECT * FROM users WHERE username=? AND password=?"
    print(f"\n  {DIM}[SQL] {CYAN}{query}{RESET}")
    print(f"  {DIM}[PARAMS] username={YELLOW}{repr(username)}{DIM}, password=***{RESET}\n")
    time.sleep(0.3)
    result = conn.execute(query, (username, password)).fetchone()
    return result

