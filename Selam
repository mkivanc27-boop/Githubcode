# ── Oyun State ──────────────────────────────────────────────────────────
class SOCState:
    def __init__(self):
        self.capacity       = 800
        self.load           = 0
        self.is_down        = True
        self.uptime_seconds = 0

        self.attack_intensity = 1.0
        self.attack_type      = "HTTP_FLOOD"
        self.wave             = 1
        self.total_attacks    = 0

        self.firewall_ips     = set()
        self.cdn              = False
        self.load_balancer    = False
        self.captcha          = False
        self.blackhole        = False
        self.scrubbing        = False
        self.waf              = False
        self.rate_limit       = False
        self.ids_active       = False

        self.blocked          = 0
        self.passed           = 0
        self.sqli_attempts    = 0
        self.sqli_blocked     = 0
        self.history          = []

        self.tickets          = []
        self.reports          = []
        self.isp_called       = False
        self.team_notified    = False
        self.ceo_briefed      = False

        self.logs             = deque(maxlen=50)
        self.alerts           = deque(maxlen=10)

        self.score            = 0
        self.actions_taken    = []

    def add_log(self, level, msg):
        entry = f"{ts()} [{level}] {msg}"
        self.logs.appendleft(entry)

    def add_alert(self, msg):
        self.alerts.appendleft(f"{RED}[ALARM {now()}]{RESET} {msg}")

# ── Simülasyon ticki ────────────────────────────────────────────────────
def tick(state):
    i = state.attack_intensity
    bot_raw  = int(random.randint(300, 600) * i)
    legit    = random.randint(40, 100)
    sqli_raw = int(random.randint(5, 20) * i)

    blocked = 0
    passed  = 0

    remaining = bot_raw
    if state.blackhole:   b=int(remaining*0.97); blocked+=b; remaining-=b
    if state.scrubbing:   b=int(remaining*0.88); blocked+=b; remaining-=b
    if state.cdn:         b=int(remaining*0.65); blocked+=b; remaining-=b
    if state.waf:         b=int(remaining*0.50); blocked+=b; remaining-=b
    if state.captcha:     b=int(remaining*0.80); blocked+=b; remaining-=b
    if state.rate_limit:  b=int(remaining*0.40); blocked+=b; remaining-=b
    for ip in state.firewall_ips:
        if random.random() < 0.02: b=int(remaining*0.01); blocked+=b; remaining-=b
    passed += remaining

    sqli_blocked = 0
    if state.waf:         sqli_blocked += int(sqli_raw * 0.95)
    elif state.ids_active: sqli_blocked += int(sqli_raw * 0.70)
    sqli_passed = sqli_raw - sqli_blocked
    state.sqli_attempts += sqli_raw
    state.sqli_blocked  += sqli_blocked

    if state.load_balancer: state.capacity = 3000
    passed += legit
    state.blocked += blocked
    state.passed  += passed
    state.total_attacks += bot_raw
    state.load = min(passed + sqli_passed * 10, state.capacity + 1200)
    state.history.append(state.load)
    if len(state.history) > 40: state.history.pop(0)

    if state.load > state.capacity:
        state.is_down = True
    elif state.load <= state.capacity and state.is_down:
        state.is_down = False
        state.add_log("INFO", "Sunucu yük normal seviyeye düştü")

    if random.random() < 0.4:
        ip = fake_bot_ip()
        ua = random.choice(USER_AGENTS)
        ep = random.choice(ENDPOINTS)
        state.add_log("WARN", f"{ip} [{country(ip)}] {random.randint(100,999)} req/s → {ep} | UA: {ua[:30]}")
    if sqli_passed > 0 and random.random() < 0.5:
        ip = fake_bot_ip()
        pl = random.choice(SQL_PAYLOADS)
        state.add_log("CRIT", f"SQL INJECTION → {ip} /login payload: {pl}")
        state.add_alert(f"SQL Injection tespit edildi! IP: {ip}")

    return bot_raw, legit, blocked, passed, sqli_raw, sqli_blocked

# ── Dashboard ───────────────────────────────────────────────────────────
def load_bar(load, cap):
    pct = min(load/cap, 1.6)
    f = int(pct*28)
    bar = "█"*min(f,28) + "░"*max(0,28-f)
    c = RED if pct>1.0 else YELLOW if pct>0.75 else GREEN
    return f"{c}[{bar}]{RESET} {load}/{cap}"

def mini_graph(hist):
    if not hist: return ""
    mx = max(hist) if max(hist)>0 else 1
    bars = " ▁▂▃▄▅▆▇█"
    out = ""
    for v in hist[-28:]:
        idx = min(int((v/mx)*8),8)
        c = RED if v>800 else YELLOW if v>500 else GREEN
        out += f"{c}{bars[idx]}{RESET}"
    return out

def si(active, label=""):
    return f"{GREEN}●{RESET}" if active else f"{DIM}○{RESET}"

