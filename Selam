# ── Ana döngü ───────────────────────────────────────────────────────────
def main():
    boot_sequence()
    state = ServerState()
    state.is_down = True
    state.current_load = 1400  # başlangıçta çökmüş
    state.traffic_history = [random.randint(800, 1400) for _ in range(15)]

    attack_info = None
    intensity = 1.0

    print_dashboard(state, attack_info)

    while True:
        try:
            raw = input(f"{GREEN}soc@defense:~${RESET} ").strip()
        except (EOFError, KeyboardInterrupt):
            print(f"\n{DIM}Çıkılıyor...{RESET}")
            break

        if not raw:
            continue

        parts = raw.split()
        cmd   = parts[0].lower()
        args  = parts[1:]

        if cmd == "exit":
            slow_print("SOC oturumu kapatılıyor...", DIM)
            break

        elif cmd == "help":
            print_help()
            continue

        elif cmd == "explain":
            topic = args[0].lower() if args else ""
            print_explain(topic)
            continue

        elif cmd == "status":
            attack_info = simulate_attack(state, intensity)
            print_dashboard(state, attack_info)
            continue

        elif cmd == "next":
            intensity = min(intensity * 1.2, 3.0)
            attack_info = simulate_attack(state, intensity)
            print_dashboard(state, attack_info)
            slow_print(f"Yeni saldırı dalgası! Yoğunluk: {intensity:.1f}x", YELLOW)
            continue

        elif cmd == "firewall":
            if not args:
                print(f"  {YELLOW}kullanım: firewall <IP> veya firewall auto{RESET}\n")
                continue
            if args[0] == "auto":
                new_ips = [fake_ip(botnet=True) for _ in range(random.randint(40, 80))]
                state.firewall_rules.extend(new_ips)
                slow_print(f"[✓] {len(new_ips)} botnet IP'si otomatik engellendi.", GREEN)
            else:
                ip = args[0]
                state.firewall_rules.append(ip)
                slow_print(f"[✓] {ip} engellendi.", GREEN)

        elif cmd == "ratelimit":
            state.rate_limits["global"] = 10
            slow_print("[✓] Rate limiting aktif: IP başına max 10 req/s", GREEN)

        elif cmd == "cdn":
            state.cdn_active = True
            slow_print("[✓] CDN / Cloudflare aktif. Trafik filtreleniyor.", GREEN)

        elif cmd == "loadbalancer":
            state.load_balancer = True
            state.max_capacity = 3000
            slow_print("[✓] Load balancer devrede. Kapasite 3000 req/s'ye çıktı.", GREEN)

        elif cmd == "captcha":
            state.captcha_active = True
            slow_print("[✓] CAPTCHA aktif. Bot trafiğinin %80'i engelleniyor.", GREEN)

        elif cmd == "blackhole":
            state.blackhole = True
            slow_print("[✓] BGP Blackhole aktif. Saldırı trafiği null route'a yönlendirildi.", YELLOW)
            slow_print("    UYARI: Meşru kullanıcılar da etkilenebilir.", YELLOW)

        elif cmd == "scrubbing":
            state.scrubbing = True
            slow_print("[✓] Traffic scrubbing merkezi aktif. Trafik temizleniyor.", GREEN)

        else:
            print(f"  {DIM}komut bulunamadı: {cmd}  ('help' yaz){RESET}\n")
            continue

        # Her komuttan sonra bir tick simüle et
        attack_info = simulate_attack(state, intensity)

        # Sunucu kurtarıldı mı?
        if state.current_load <= state.max_capacity and state.is_down:
            state.is_down = False
            print_dashboard(state, attack_info)
            print(f"\n  {GREEN}{'█'*55}")
            print(f"  █  🎉 BAŞARILI! Sunucu kurtarıldı!                   █")
            print(f"  █  Servis yeniden çevrimiçi.                         █")
            print(f"  {'█'*55}{RESET}\n")
        else:
            print_dashboard(state, attack_info)

        if state.is_down:
            remaining = state.current_load - state.max_capacity
            slow_print(f"  Sunucu hâlâ çökmüş. Kapasiteyi {remaining} req/s daha azaltman gerekiyor.", YELLOW)

if __name__ == "__main__":
    main()
