def cmd_logs(state, args):
    print(f"\n  {CYAN}SON LOGLAR:{RESET}")
    flt = args[0].lower() if args else ""
    count = 0
    for log in state.logs:
        if flt == "crit" and "CRIT" not in log: continue
        if flt == "warn" and "WARN" not in log: continue
        color = RED if "CRIT" in log else YELLOW if "WARN" in log else DIM
        print(f"  {color}{log}{RESET}")
        count += 1
        if count >= 20: break
    print()

