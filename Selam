import os
import time
import sys

# Renk Ayarları
G = '\033[92m' # Yeşil
R = '\033[91m' # Kırmızı
Y = '\033[93m' # Sarı
C = '\033[96m' # Turkuaz
B = '\033[94m' # Mavi
RESET = '\033[0m'

def typing(text, speed=0.04):
    for char in text:
        sys.stdout.write(char)
        sys.stdout.flush()
        time.sleep(speed)
    print()

def clear():
    os.system('cls' if os.name == 'nt' else 'clear')

def start_game():
    clear()
    typing(R + ">>> INTRUSION DETECTED IN E-CORP CORE..." + RESET, 0.06)
    typing(G + ">>> BYPASSING FIREWALL... [DONE]", 0.03)
    typing(G + ">>> CONNECTED TO NODE: 192.168.1.1", 0.03)
    time.sleep(1)
    
    fbi_level = 0
    has_key = False
    
    while True:
        print(f"\n{B}[Hacker: Elliot] [Tehlike: %{fbi_level}]{RESET}")
        cmd_input = input(f"{G}root@e-corp:~# {RESET}").strip().lower().split()
        
        if not cmd_input: continue
        cmd = cmd_input[0]

        # --- YARDIM MENÜSÜ ---
        if cmd == "help":
            print(f"{C}ls{RESET} - Dosyaları gör")
            print(f"{C}cat [dosya]{RESET} - İçeriği oku")
            print(f"{C}hack [hedef]{RESET} - Sisteme sız (FBI riskli!)")
            print(f"{C}whoami{RESET} - Kimliğini sorgula")
            print(f"{C}shred [dosya]{RESET} - Dosyayı yok et")
            print(f"{C}status{RESET} - FBI takip durumunu gör")

        # --- DOSYA SİSTEMİ ---
        elif cmd == "ls":
            print("borc_listesi.db  wellick_mail.txt  kamera_sistem.sh  gizli_anahtar.enc")

        elif cmd == "whoami":
            typing(Y + "...Ben kimim? Bazen Mr. Robot konuşuyor, bazen ben. Ama bugün devrim konuşacak." + RESET)

        elif cmd == "cat":
            if "wellick_mail.txt" in cmd_input:
                typing("Mail from Tyrell: 'Elliot, birlikte dünyayı değiştirebiliriz. Cevabını bekliyorum.'")
            elif "gizli_anahtar.enc" in cmd_input:
                typing(R + "[!] DOSYA ŞİFRELİ! Açmak için 'hack' komutunu kullanmalısın." + RESET)
            elif "borc_listesi.db" in cmd_input:
                typing("İçerik: 14.5 Trilyon Dolar borç kaydı. Tüm dünya bu dosyaya hapsolmuş.")
            else:
                print("Erişim engellendi.")

        # --- AKSİYONLAR ---
        elif cmd == "hack":
            if "gizli_anahtar.enc" in cmd_input:
                typing(Y + "Şifre kırılıyor... Lütfen bekleyin..." + RESET)
                time.sleep(3)
                typing(G + ">> ŞİFRE: 'fsociety2026' BULUNDU!" + RESET)
                has_key = True
                fbi_level += 15
            elif "kamera_sistem.sh" in cmd_input:
                typing(B + ">> E-Corp güvenlik kameraları bypass edildi. Şu an koridorları görüyorsun." + RESET)
                fbi_level += 20
            else:
                print("Hedef belirtilmedi.")

        elif cmd == "shred":
            if "borc_listesi.db" in cmd_input:
                if has_key:
                    typing(R + ">> 5/9 OPERASYONU BAŞLADI..." + RESET)
                    time.sleep(2)
                    typing(G + "[SON: DÜNYA DEĞİŞTİ] Tüm borçlar silindi. E-Corp iflas etti. Kazandın Elliot." + RESET)
                    break
                else:
                    typing(Y + "Hata: Önce 'gizli_anahtar.enc' dosyasını hackleyip anahtarı almalısın!" + RESET)
            else:
                print("Silinecek kritik dosya bulunamadı.")

        elif cmd == "status":
            typing(f"İzlenme oranı: %{fbi_level}")
            if fbi_level > 50: typing(R + "DİKKAT: FBI konumunu tespit etmek üzere!" + RESET)

        elif cmd == "exit":
            typing("Sistemden çıkılıyor... Güle güle Elliot.")
            break

        else:
            print("Bilinmeyen komut. Hata yapman FBI'ın işini kolaylaştırıyor.")
            fbi_level += 5

        # --- KAYBETME DURUMU ---
        if fbi_level >= 100:
            typing(R + "\n[!!!] KONUMUN BULUNDU! Kapı kırılıyor... FBI İÇERİ GİRDİ!" + RESET)
            typing("Hapis hayatına hazır ol Elliot.")
            break

if __name__ == "__main__":
    start_game()
