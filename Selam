def cmd_login(conn, args, state):
    if len(args) < 2:
        print(f"  {YELLOW}kullanım: login <kullanici> <sifre>{RESET}\n")
        return
    username = args[0]
    password = " ".join(args[1:])
    fn = secure_login if state["secure"] else vulnerable_login
    result = fn(conn, username, password)

    if result:
        state["user"] = result
        glitch()
        print(f"  {GREEN}{'█'*44}")
        print(f"  █  ERİŞİM SAĞLANDI                         █")
        print(f"  █  kullanici : {result[1]:<28}█")
        print(f"  █  rol       : {result[3]:<28}█")
        print(f"  █  yetki     : {result[4]:<28}█")
        print(f"  {'█'*44}{RESET}\n")
        if not state["secure"] and "'" in username:
            print(f"  {RED}[!] SQL INJECTION ile giriş yapıldı! Şifre kontrol edilmedi.{RESET}")
            print(f"  {DIM}    'fix' komutu ile açığı kapatabilirsin.{RESET}\n")
    else:
        print(f"  {RED}[✗] ERİŞİM REDDEDİLDİ — hatalı kullanıcı adı veya şifre{RESET}\n")

def cmd_sqlmap(conn, args, state):
    target = args[0] if args else "admin"
    payloads = [
        (f"admin'--",       "x"),
        (f"' OR '1'='1",   "herhangi"),
        (f"' OR 1=1--",    ""),
        (f"' OR 'x'='x",  "x"),
        (f"admin' #",      ""),
    ]
    print(f"\n  {GREEN}[sqlmap] hedef: {target} | mod: {'GÜVENLİ' if state['secure'] else 'SAVUNMASIZ'}{RESET}")
    print(f"  {DIM}{'─'*50}{RESET}\n")
    time.sleep(0.4)

    found = False
    for uname, pwd in payloads:
        time.sleep(0.35)
        if state["secure"]:
            result = secure_login(conn, uname, pwd)
        else:
            result = vulnerable_login(conn, uname, pwd)

        status = f"{RED}AÇIK BULUNDU ✓{RESET}" if result else f"{DIM}engellendi{RESET}"
        print(f"  {DIM}{uname:<35}{RESET} → {status}")

        if result and not state["secure"]:
            found = True
            print(f"\n  {RED}[!] INJECTION BAŞARILI!")
            print(f"  [!] kullanici: {result[1]}  yetki: {result[4]}{RESET}")
            state["user"] = result
            break

    print()
    if not found:
        if state["secure"]:
            print(f"  {GREEN}[✓] tüm payload'lar engellendi. sistem güvende.{RESET}\n")
        else:
            print(f"  {YELLOW}[?] otomatik bulunamadı. 'login' ile manuel dene.{RESET}\n")

