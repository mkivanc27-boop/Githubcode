# ── Renkler ────────────────────────────────────────────────────────────
RED="\033[91m"; GREEN="\033[92m"; YELLOW="\033[93m"; CYAN="\033[96m"
WHITE="\033[97m"; DIM="\033[90m"; BOLD="\033[1m"; BLINK="\033[5m"; RESET="\033[0m"

def clear(): os.system("cls" if os.name == "nt" else "clear")
def now(): return datetime.now().strftime("%H:%M:%S")
def ts(): return f"{DIM}[{now()}]{RESET}"

def slow(text, color=DIM, spd=0.013):
    print(color, end="", flush=True)
    for ch in text:
        print(ch, end="", flush=True)
        time.sleep(spd)
    print(RESET)

def alert(text): slow(f"  ⚠  {text}", RED, 0.014)
def ok(text):    slow(f"  ✓  {text}", GREEN, 0.012)
def info(text):  slow(f"  ℹ  {text}", CYAN, 0.011)
def warn(text):  slow(f"  !  {text}", YELLOW, 0.011)

